# ─── Django ──────────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace_with_a_random_django_secret_key
DEBUG=False  # Set to True only for local development
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── MySQL Database ──────────────────────────────────────────
DB_NAME=games_dictionary
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ─── Email (Gmail SMTP) ──────────────────────────────────────
# Use a Gmail App Password, NOT your regular Gmail password
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your_gmail@gmail.com
EMAIL_HOST_PASSWORD=your_gmail_app_password

# ─── NextAuth Internal Secret ──────────────────────────────
# Must match NEXTAUTH_INTERNAL_SECRET in web/.env.local
NEXTAUTH_INTERNAL_SECRET=replace_with_same_secret_as_web
